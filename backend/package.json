{
  "name": "smart-deploy-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "worker": "bun src/workers/buildWorker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:studio": "dotenv -e .env -- prisma studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@kubernetes/client-node": "^1.4.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bullmq": "^5.74.1",
    "dockerode": "^4.0.10",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "simple-git": "^3.36.0"
  },
  "module": "index.ts",
  "private": true,
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "@types/dockerode": "^4.0.1",
